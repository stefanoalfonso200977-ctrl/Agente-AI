{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" }
      },
      "required": ["uid", "email"]
    },
    "Document": {
      "title": "Document",
      "description": "Uploaded document metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Document ID" },
        "ownerUid": { "type": "string", "description": "Owner UID" },
        "name": { "type": "string", "description": "Document name" },
        "type": { "type": "string", "description": "Document type (pdf, word, image)" },
        "createdAt": { "type": "string", "description": "Creation timestamp" }
      },
      "required": ["id", "ownerUid", "name", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/documents/{docId}": {
      "schema": { "$ref": "Document" },
      "description": "Uploaded documents"
    }
  }
}
